{#- _includes/layouts/base.njk
    Base layout — every page extends this.
    Provides: <head>, font loading, body wrapper.
    Pages pass in: title, description, bodyClass (optional) -#}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Geist:wght@300;400;500&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/shared.css" />
  {% block styles %}{% endblock %}
</head>
<body>
  {% block body %}{% endblock %}
</body>
</html>
